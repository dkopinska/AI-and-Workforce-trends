    <dashboard name='Story 1' type='storyboard'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97856' id='1' param='vert' removable='false' type-v2='layout-flow' w='98706' x='647' y='1072'>
            <zone h='6702' id='3' type-v2='title' w='98706' x='647' y='1072' />
            <zone h='13539' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98706' x='647' y='7774' />
            <zone h='77615' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98706' x='647' y='21313'>
              <flipboard active-id='6' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Which countries are most AI-ready?' captured-sheet='AI Readiness score by Country in 2025' id='6'>
                    <capturedDeltas>
                      <worksheet name='AI Readiness score by Country in 2025'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.18d4vyb0luteia1dmv82w00ypl66].[Latitude (generated)]' field-type='quantitative' max='20656419.253499594' min='-5360849.3984621316' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.18d4vyb0luteia1dmv82w00ypl66].[Longitude (generated)]' field-type='quantitative' max='73187726.951473996' min='14451771.990991756' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='AI vs Reskilling Investment and Jobs Created vs Displaced in 2025' captured-sheet='AI and Reskilling investment and created and displaced jobs in 2025' id='7'>
                    <capturedDeltas>
                      <worksheet name='Number of Created Jobs vs Displaced Jobs in 2025'>
                        <highlight field='[federated.18d4vyb0luteia1dmv82w00ypl66].[:Measure Names]'>
                          <bucket-selection />
                        </highlight>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Does AI destroy jobs?' captured-sheet='Correlation matrix' id='14' />
                  <story-point caption='Effects of AI investment' captured-sheet='Total AI investment vs Job Creation, Average Productivity Index and Automation Rate' id='8' />
                  <story-point caption='Effects of Automation' captured-sheet='Average Automation Rate vs Total Job Displacement and Average Salary Rate' id='12'>
                    <capturedDeltas>
                      <worksheet name='Average Automation Rate vs Average Salary'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.18d4vyb0luteia1dmv82w00ypl66].[avg:Automation_Rate_Percent:qk]' field-type='quantitative' max='63.811060190668925' min='-0.41056910919120515' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.18d4vyb0luteia1dmv82w00ypl66].[avg:Average_Salary_USD:qk]' field-type='quantitative' max='161545.9108403771' min='6197.3118955517839' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                        <selection-collection>
                          <node-selection select-tuples='false'>
                            <oriented-node-reference orientation='vertical'>
                              <node-reference>
                                <axis>[federated.18d4vyb0luteia1dmv82w00ypl66].[avg:Automation_Rate_Percent:qk]</axis>
                              </node-reference>
                              <page-reference />
                            </oriented-node-reference>
                          </node-selection>
                        </selection-collection>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Effects of AI Readiness Score' captured-sheet='Average AI Readiness vs Average Productivity Rate and AI Policy Index in 2025' id='10'>
                    <capturedDeltas>
                      <worksheet name='AI Readiness Score vs Average AI Policy Index'>
                        <selection-collection />
                      </worksheet>
                      <worksheet name='Average Employment Rate in 2025'>
                        <selection-collection>
                          <node-selection select-tuples='false'>
                            <oriented-node-reference orientation='vertical'>
                              <node-reference>
                                <axis>[federated.18d4vyb0luteia1dmv82w00ypl66].[avg:Employment_Rate_Percent:qk]</axis>
                              </node-reference>
                              <page-reference />
                            </oriented-node-reference>
                          </node-selection>
                        </selection-collection>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Which country?' captured-sheet='Which country?' id='17' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='55630' id='6' story-point-id='6' type-v2='text' w='12783' x='86327' y='43566'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>AI readiness index:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'> the extent to which a country is ready to develop, adopt, and scale AI technologies.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>AI policy index: </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>the strength, maturity, and structure of a country’s AI governance and strategy framework.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Productivity index:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'> economic efficiency/output, typically output per worker or output per hour.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='11126' hidden='true' id='7' story-point-id='8' type-v2='text' w='87945' x='1375' y='89008'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>AI investment explains 43% of the differences in job creation, 28% of the differences in productivity and  14% in wage differences across countries over the years. AI investment had a much stronger effect on these factors than Reskilling Investment which justifies higher spending on AI.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='14075' id='9' story-point-id='6' type-v2='text' w='12406' x='623' y='73056'>
          <formatted-text>
            <run fontsize='8'>Dataset source: Kaggle</run>
            <run>Æ&#10;</run>
            <run fontsize='8'>Countries: 20 </run>
            <run>Æ&#10;</run>
            <run fontsize='8'>Time period: 2015-2025</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='19659' hidden='true' id='10' story-point-id='14' type-v2='text' w='93123' x='5340' y='76935'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>AI investment </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>is strongly linked to more job creation (r = 0.65) and moderately higher productivity (r = 0.53), meaning countries that spend more on AI tend to grow and create jobs rather than lose them.</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>AI readiness </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>is also connected to more productivity (r = 0.56), and AI policy index (r = 0.51), suggesting that preparation and governance matter for AI capability.</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Automation</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'> is linked to  higher job displacement (r = 0.42) but more strongly linked to higher wages (r = 0.49), suggesting that it is lower wage jobs that are being lost.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Overall, the results point to AI driving growth and job creation in countries that are well prepared.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='12735' hidden='true' id='11' story-point-id='12' type-v2='text' w='81634' x='2751' y='85523'>
          <formatted-text>
            <run fontsize='10'>Automation rate explained 17% of  differences in job displacement and 24% of variance in average salary (both relationships being positive), suggesting that automation replaces lower paid jobs.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='19035' hidden='true' id='12' story-point-id='10' type-v2='text' w='78560' x='4612' y='81501'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>AI readiness explains 32% of the differences in productivity levels and 26% of the differences in AI policy strenght.  This suggests that countries better prepared for AI with stronger infrastructure, skills, and systems, tend to perform significantly better economically and that governance plays an important supporting role in building AI capability. </run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{7E4662EA-1DC7-4851-9FF5-25E1B7D7D3D2}' />
    </dashboard>
